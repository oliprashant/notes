# ─────────────────────────────────────────────────────────────
#  NoteFlow — Environment Variables
#  Copy this file to .env and fill in your values.
#  NEVER commit your actual .env file to version control.
# ─────────────────────────────────────────────────────────────

# ── Firebase Configuration ────────────────────────────────────
# Get these from your Firebase project:
# Firebase Console → Project Settings → General → Your apps → SDK setup
VITE_FIREBASE_API_KEY=AIza...
VITE_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-project-id
VITE_FIREBASE_STORAGE_BUCKET=your-project.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=123456789
VITE_FIREBASE_APP_ID=1:123456789:web:abcdef

# ── Groq API Key (for AI note summaries) ──────────────────────
# Get from: https://console.groq.com/keys
# ⚠️  WARNING: In production, proxy this through a backend server
#    to prevent your key from being exposed in the browser.
VITE_GROQ_API_KEY=gsk_...

