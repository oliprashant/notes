rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function signedIn() {
      return request.auth != null;
    }

    function isSelf(uid) {
      return signedIn() && request.auth.uid == uid;
    }

    function userDoc(uid) {
      return get(/databases/$(database)/documents/users/$(uid));
    }

    function profileVisible(uid) {
      return exists(/databases/$(database)/documents/users/$(uid))
        && userDoc(uid).data.visibility == 'public';
    }

    function canReadProfile(uid) {
      return isSelf(uid) || profileVisible(uid);
    }

    function isSafeSocialCountUpdate() {
      return signedIn()
        && request.resource.data.diff(resource.data).changedKeys().hasOnly([
          'followersCount',
          'followingCount',
          'updatedAt'
        ]);
    }

    function noteDoc(noteId) {
      return get(/databases/$(database)/documents/notes/$(noteId));
    }

    function noteIsPublic(noteId) {
      return exists(/databases/$(database)/documents/notes/$(noteId))
        && (
          noteDoc(noteId).data.visibility == 'public'
          || noteDoc(noteId).data.shared == true
        );
    }

    function canReadNote(noteId) {
      return noteIsPublic(noteId)
        || (
          signedIn()
          && (
            noteDoc(noteId).data.uid == request.auth.uid
            || (
              request.auth.token.email != null
              && request.auth.token.email in noteDoc(noteId).data.collaborators
            )
          )
        );
    }

    // Allow non-owners to update only social counters on notes.
    function isSafeCounterUpdate() {
      return signedIn()
        && request.resource.data.diff(resource.data).changedKeys().hasOnly([
          'likeCount',
          'commentCount',
          'bookmarkCount',
          'lastInteractionAt',
          'updatedAt'
        ])
        && request.resource.data.uid == resource.data.uid;
    }

    match /users/{userId} {
      allow read: if canReadProfile(userId);
      allow create, delete: if isSelf(userId);
      allow update: if isSelf(userId) || isSafeSocialCountUpdate();

      match /bookmarks/{noteId} {
        allow read, create, update, delete: if isSelf(userId);
      }

      match /badges/{badgeId} {
        allow read: if canReadProfile(userId);
        allow create, update, delete: if isSelf(userId);
      }
    }

    match /usernames/{username} {
      allow read: if true;
      allow create: if signedIn()
        && request.resource.data.uid == request.auth.uid;
      allow update, delete: if signedIn() && resource.data.uid == request.auth.uid;
    }

    match /notes/{noteId} {
      // Query-safe read rule for top-level notes queries.
      allow read: if (
        resource.data.visibility == 'public'
        || resource.data.shared == true
        || (
          signedIn()
          && (
            resource.data.uid == request.auth.uid
            || (
              request.auth.token.email != null
              && resource.data.collaborators != null
              && request.auth.token.email in resource.data.collaborators
            )
          )
        )
      );

      allow create: if signedIn()
        && request.resource.data.uid == request.auth.uid
        && request.resource.data.keys().hasAll([
          'uid',
          'title',
          'content',
          'visibility',
          'createdAt',
          'updatedAt'
        ])
        && request.resource.data.visibility in ['public', 'private'];

      allow update: if (
        signedIn()
        && (
          resource.data.uid == request.auth.uid
          || (
            request.auth.token.email != null
            && request.auth.token.email in resource.data.collaborators
          )
          || isSafeCounterUpdate()
        )
      );

      allow delete: if signedIn() && resource.data.uid == request.auth.uid;

      match /likes/{likeUserId} {
        allow read: if canReadNote(noteId);
        allow create, delete: if signedIn() && request.auth.uid == likeUserId && canReadNote(noteId);
        allow update: if false;
      }

      match /comments/{commentId} {
        allow read: if canReadNote(noteId);
        allow create: if signedIn()
          && canReadNote(noteId)
          && request.resource.data.uid == request.auth.uid;
        allow update, delete: if signedIn() && resource.data.uid == request.auth.uid;
      }

      match /history/{historyId} {
        allow read: if signedIn() && canReadNote(noteId);
        allow create: if signedIn() && noteDoc(noteId).data.uid == request.auth.uid;
        allow update, delete: if signedIn() && noteDoc(noteId).data.uid == request.auth.uid;
      }
    }

    match /followers/{userId}/userFollowers/{followerId} {
      allow read: if true;
      allow create, delete: if signedIn() && request.auth.uid == followerId;
      allow update: if false;
    }

    match /following/{userId}/userFollowing/{followedId} {
      allow read: if signedIn();
      allow create, delete: if signedIn() && request.auth.uid == userId;
      allow update: if false;
    }

    match /notifications/{userId}/items/{notificationId} {
      allow read: if isSelf(userId);
      allow create: if signedIn() && request.resource.data.actorUid == request.auth.uid;
      allow update, delete: if isSelf(userId);
    }

    match /activities/{activityId} {
      allow create: if signedIn() && request.resource.data.actorUid == request.auth.uid;
      allow read: if signedIn()
        && (
          resource.data.actorUid == request.auth.uid
          || resource.data.targetOwnerUid == request.auth.uid
        );
      allow update, delete: if false;
    }

    match /sessions/{userId}/userSessions/{sessionId} {
      allow read, create, update, delete: if isSelf(userId);
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
